# ===== 推送渠道全局配置（JSON，单个环境变量，展示用）=====
# 生产环境实际由 docker-compose 覆盖此变量，这里仅作为字段示例展示。
# FastapiApp / RPA-Browser / notify-service 共用同一份 NOTIFY_CONFIG。
# 字段与 NotificationConfig 一致（pushme_key / push_plus_token / smtp_* / tg_* 等），
# 只填需要启用的渠道即可；pushme_url / push_plus_url 可省略（使用默认端点）。
# 注意：.env 中请用单引号包裹整段 JSON，避免内部双引号/特殊字符被截断。
MESSAGE_CONFIG='{"pushme_key":"<PUSHME_KEY>","pushme_url":"https://push.i-i.me","push_plus_token":"<PUSHPLUS_TOKEN>","push_plus_url":"http://www.pushplus.plus/send","smtp_server":"<SMTP_SERVER>","smtp_ssl":"true","smtp_email":"<SMTP_EMAIL>","smtp_password":"<SMTP_PASSWORD>","smtp_name":"<SMTP_NAME>","tg_bot_token":"","tg_user_id":"","tg_api_host":"","tg_proxy_host":"","tg_proxy_port":""}'
UNIDBG_HOST=unidbg
UNIDBG_PORT=23335
V2RAY_HOST=
V2RAY_PORT=10809
LLAMA_HOST=llama_cpp
LLAMA_PORT=8080
PROXY_SERVER=
MILVUS_HOST=standalone
MILVUS_PORT=19530
MESSAGE_SERVICE_HOST=message-service
MESSAGE_SERVICE_PORT=18739
SHOW_LOG=1
# 开发环境配置: 0=生产环境(启动定时任务), 1=开发环境(不启动定时任务)
IS_DEV=0

# 外部 LLM API 列表（按顺序优先使用，全部失败后回退到本地 Ollamalmstuidio）
# JSON 格式，例如：llm_apis='[{"base_url":"https://...","model_name":"gpt-3.5","token":"sk-xxx"}]'
# 或用双下划线：llm_apis__0__base_url=https://...  llm_apis__0__model_name=gpt-3.5  llm_apis__0__token=sk-xxx
llm_apis=[]